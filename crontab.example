# TradeAnalytics - Volume Analyzer Crontab 配置示例
# 
# 安装方法:
# 1. 编辑此文件，修改路径为实际路径
# 2. 运行: crontab -e
# 3. 复制下面的配置到 crontab 中
# 4. 保存退出
#
# 查看当前 crontab: crontab -l
# 查看日志: tail -f /path/to/TradeAnalytics/logs/volume_analyzer.log

# ============================================================
# 基础配置 - 每个交易日下午3:30执行完整分析
# ============================================================

# 完整版：更新数据 + 分析 + 推送
30 15 * * 1-5 cd /path/to/TradeAnalytics && /usr/bin/python3 src/volume_analyzer.py >> logs/volume_analyzer.log 2>&1

# ============================================================
# 高级配置 - 分离数据更新和分析
# ============================================================

# 方案1：上午更新数据，下午只分析
# 09:00 更新股票列表和历史数据
0 9 * * 1-5 cd /path/to/TradeAnalytics && /usr/bin/python3 -c "from src.data_downloader import DataDownloader; d=DataDownloader(); d.update_stock_list(); d.update_all_stocks()" >> logs/data_update.log 2>&1

# 15:30 分析数据并推送（不更新数据）
30 15 * * 1-5 cd /path/to/TradeAnalytics && /usr/bin/python3 src/volume_analyzer.py --no-update >> logs/volume_analyzer.log 2>&1

# ============================================================
# 仅分析配置 - 不发送通知（用于测试）
# ============================================================

# 只分析，不发送邮件和推送
30 15 * * 1-5 cd /path/to/TradeAnalytics && /usr/bin/python3 src/volume_analyzer.py --no-email --no-notification >> logs/volume_analyzer.log 2>&1

# ============================================================
# 使用 Shell 脚本运行
# ============================================================

# 使用封装好的 shell 脚本
30 15 * * 1-5 /path/to/TradeAnalytics/run_volume_analyzer.sh

# ============================================================
# 时间格式说明
# ============================================================
#
# 分钟 (0-59)
# |   小时 (0-23)
# |   |   日期 (1-31)
# |   |   |   月份 (1-12)
# |   |   |   |   星期 (0-7, 0和7都表示周日)
# |   |   |   |   |
# *   *   *   *   *   命令
#
# 特殊字符:
# * - 任意值
# , - 多个值 (例: 1,3,5)
# - - 范围 (例: 1-5)
# / - 步长 (例: */10 表示每10分钟)
#
# ============================================================
# 常用时间示例
# ============================================================
#
# 每个交易日下午3:30:
# 30 15 * * 1-5
#
# 每天下午4:00:
# 0 16 * * *
#
# 每小时执行:
# 0 * * * *
#
# 每30分钟执行:
# */30 * * * *
#
# 交易时段每30分钟执行 (9:00-15:00):
# */30 9-15 * * 1-5
#
# 每周一上午9:00:
# 0 9 * * 1
#
# 每月1日凌晨2:00:
# 0 2 1 * *
#
# ============================================================
# 环境变量配置（可选）
# ============================================================
#
# 在 crontab 中设置环境变量（放在任务之前）:
# SHELL=/bin/bash
# PATH=/usr/local/bin:/usr/bin:/bin
# MAILTO=""
#
# TA_EMAIL_SENDER=your_email@qq.com
# TA_EMAIL_AUTH=your_auth_code
# TA_SERVERCHAN_KEY=your_sendkey
#
# ============================================================
# 日志轮转（推荐配置）
# ============================================================
#
# 创建文件: /etc/logrotate.d/tradeanalytics
#
# /path/to/TradeAnalytics/logs/*.log {
#     daily
#     rotate 30
#     compress
#     missingok
#     notifempty
#     copytruncate
# }
#
# ============================================================
