[Paths]
data_dir = ./data
daily_dir = ./data/daily
stocks_dir = ./data/stocks
results_dir = ./data/results
logs_dir = ./logs

[DataSource]
# 数据源选择: akshare 或 baostock
# akshare: 东方财富数据，实时性好但可能不稳定
# baostock: 证券宝数据，更稳定可靠，推荐使用
source = baostock
update_stock_list_days = 1

[Analysis]
ma_period = 20
volume_ratio_threshold = 5.0
min_history_days = 30

[Scheduler]
enabled = true
run_time = 15:30
weekdays_only = true

[Download]
# 并发线程数：服务器限制，使用单线程避免拒绝连接
max_workers = 1
retry_times = 3
retry_delay = 5
# 每日下载量限制（MB），0表示无限制，首次运行建议设为0
daily_download_limit_mb = 0

[MonsterStock]
# 妖股筛选参数
lookback_days = 30
volume_surge_ratio = 3.0
turnover_threshold = 5.0
min_score = 30
max_market_cap = 200
consecutive_limit_days = 2
rsi_strong_threshold = 60
price_rise_pct = 10.0

[GUI]
window_width = 1200
window_height = 800
theme = default

[Email]
# 邮件发送配置(QQ邮箱SMTP)
# 也可通过环境变量设置敏感字段:
#   TA_EMAIL_SENDER   - 发件人邮箱
#   TA_EMAIL_AUTH     - 邮箱授权码
#   TA_EMAIL_RECEIVER - 收件人邮箱
enabled = false
smtp_server = smtp.qq.com
smtp_port = 465
smtp_ssl = true
sender_email =
sender_name = TradeAnalytics
# QQ邮箱授权码(非QQ密码): 登录QQ邮箱->设置->账户->POP3/SMTP服务->开启->获取授权码
auth_code =
# 收件人邮箱(多个用逗号分隔)
receiver_emails =

[Notification]
# 消息推送开关
enabled = false
# 推送类型: serverchan, qywechat, pushplus, wechat_official
push_type = serverchan
# Server酱SendKey（从 https://sct.ftqq.com/ 获取）
# 也可通过环境变量 TA_SERVERCHAN_KEY 设置
serverchan_key =
# 企业微信机器人Webhook地址
qywechat_webhook =
# PushPlus Token（从 http://www.pushplus.plus/ 获取）
pushplus_token =
# 微信公众号配置（需要认证服务号）
wechat_appid =
wechat_secret =
wechat_template_id =
wechat_openids =
# 推送配置
push_history_days = 3
push_max_stocks = 20
